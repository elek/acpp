<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base launch theme. The real Material 3 / Material You styling is applied in
         Compose via AcppTheme; this only controls the window before Compose draws. -->
    <style name="Theme.Acpp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/acpp_window_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
